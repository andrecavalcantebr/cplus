#include "person.hplus"

int main(void) {
    Person alice;
    unique Person *pAlice = &alice;
    person_set_name(pAlice, "Alice");
    person_set_age(pAalice, 30);

    Person bob;
    person_set_name(&bob, "Bob");
    person_set_age(&bob, 25);

    person_print(pAlice);
    person_print(&bob);

    return 0;
}
